# Copy to .env for local development

# PostgreSQL — matches docker-compose.yml (container on host port 5433)
DATABASE_URL=postgresql+psycopg://pricing:pricing@localhost:5433/pricing_simulator

# If you use your own Postgres on the default port instead, create user/db and set e.g.:
# DATABASE_URL=postgresql+psycopg://YOUR_USER:YOUR_PASSWORD@localhost:5432/pricing_simulator

# Comma-separated origins for the Vite dev server
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# After `cd frontend && npm run build`, serve the SPA from the API (production)
STATIC_DIR=frontend/dist
