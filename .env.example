# Copy to .env for local development

# PostgreSQL (use docker-compose or a local instance)
DATABASE_URL=postgresql+psycopg://pricing:pricing@localhost:5432/pricing_simulator

# Comma-separated origins for the Vite dev server
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# After `cd frontend && npm run build`, serve the SPA from the API (production)
STATIC_DIR=frontend/dist
